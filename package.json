{
  "name": "seclang-vscode",
  "displayName": "SecLang - WGE Rules Language Support",
  "description": "Syntax highlighting, code completion and snippets for SecLang/ModSecurity WAF rules",
  "version": "1.0.6",
  "publisher": "BowenChen",
  "author": {
    "name": "WAF Security Engineer"
  },
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "seclang",
    "modsecurity",
    "waf",
    "security",
    "firewall",
    "owasp",
    "crs"
  ],
  "activationEvents": [
    "onLanguage:seclang"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "seclang",
        "aliases": [
          "SecLang",
          "ModSecurity",
          "seclang"
        ],
        "extensions": [
          ".conf",
          ".seclang",
          ".modsec"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "seclang",
        "scopeName": "source.seclang",
        "path": "./syntaxes/seclang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "seclang",
        "path": "./snippets/seclang.snippets.json"
      }
    ],
    "configuration": {
      "title": "SecLang",
      "properties": {
        "seclang.enableCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Enable SecLang code completions"
        },
        "seclang.enableHover": {
          "type": "boolean",
          "default": true,
          "description": "Enable hover documentation for SecLang keywords"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-yarn --no-dependencies",
    "gen-docs": "node scripts/generate-docs.js"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HawkeyeTW/WGE-Syntax-Highlighting"
  },
  "homepage": "https://github.com/HawkeyeTW/WGE-Syntax-Highlighting",
  "bugs": {
    "url": "https://github.com/HawkeyeTW/WGE-Syntax-Highlighting/issues"
  }
}
